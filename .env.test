## App
PORT=3000
NODE_ENV=test

## Swagger / OpenAPI
# Set to 'false' to disable completely (recommended in production)
SWAGGER_ENABLED=true
# URL path for the Swagger UI
SWAGGER_PATH=docs
# Write the generated OpenAPI spec on app boot / swagger:generate
SWAGGER_WRITE_ON_BOOT=true
SWAGGER_OUTPUT_PATH=docs/openapi.json

## PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=classurency_test

## Crypto keys (required)
# IMPORTANT: both must be 32 bytes, base64-encoded. Example generation:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# MASTER KEY is used for JWT tokens and signing
CLASSURENCY_MASTER_KEY=xIVJ7fvB+dOQ6RlpT3RjlJX0MbC+qZTL+ehm0Ke+MrY=
# CARD EXPORT KEY is used for encrypting and decrypting private keys for the NFC card
CLASSURENCY_CARD_EXPORT_KEY=mCrJmYYtOoANlv0xqZB/kixPhCmlORz/821hHvAGJEs=

